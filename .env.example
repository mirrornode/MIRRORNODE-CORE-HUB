# ── MIRRORNODE Environment Variables ─────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Canon ─────────────────────────────────────────────────────────────────────
CANON_ROOT=./canon

# ── Stripe (Osiris) ───────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Get this after creating a webhook endpoint in Stripe Dashboard
# Endpoint URL: https://api.mirrornode.io/osiris/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Agent Ports ────────────────────────────────────────────────────────────────
LUCIAN_PORT=7700
OSIRIS_PORT=7701
HERMES_PORT=7702

# ── API Gateway ───────────────────────────────────────────────────────────────
# Public-facing base URL for the MIRRORNODE API
MIRRORNODE_API_URL=https://api.mirrornode.io
# Internal base URL for local development
MIRRORNODE_API_URL_LOCAL=http://localhost:7700

# ── Platform (Next.js) ────────────────────────────────────────────────────────
# These are exposed to the browser — must be prefixed NEXT_PUBLIC_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_MIRRORNODE_API_URL=https://api.mirrornode.io

# ── Vercel ────────────────────────────────────────────────────────────────────
# Set these in Vercel project settings — do not put real values here
VERCEL_ENV=production
VERCEL_URL=mirrornode.io

# ── Database / Persistence (Thoth — future) ────────────────────────────────────
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...
